{
  "color": {
    "ui": {
      "background": {
        "canvas": {
          "$type": "color",
          "$value": {
            "value": "{color.base.neutral.100}"
          },
          "cssProp": "bg"
        },
        "surface": { "$type": "color", "$value": "{color.base.white}" },
        "surfaceInverted": {
          "$type": "color",
          "$value": "{color.base.neutral.700}"
        },
        "muted": {
          "$type": "color",
          "$value": "{color.base.neutral.100}"
        },
        "input": { "$type": "color", "$value": "{color.base.white}" },
        "inputAutofill": { "$type": "color", "$value": "#e8f0fe" },
        "skeleton": {
          "$type": "color",
          "$value": "{color.base.neutral.200}"
        },
        "skeletonHighlight": {
          "$type": "color",
          "$value": "{color.base.neutral.300}"
        },
        "tooltip": {
          "$type": "color",
          "$value": {
            "value": "{color.base.black}"
          },
          "cssProp": "bg-tooltip"
        },
        "backdrop": {
          "$type": "color",
          "$value": {
            "value": "{color.base.neutral.700}"
          },
          "cssProp": "bg-backdrop"
        }
      },
      "border": {
        "light": {
          "$type": "color",
          "$value": {
            "value": "{color.base.neutral.100}"
          },
          "cssProp": "border-color-light"
        },
        "default": {
          "$type": "color",
          "$value": {
            "value": "{color.base.neutral.200}"
          },
          "cssProp": "border-color"
        },
        "dark": {
          "$type": "color",
          "$value": {
            "value": "{color.base.neutral.300}"
          },
          "cssProp": "border-color-dark"
        },
        "focus": {
          "$type": "color",
          "$value": "#0071ff",
          "cssProp": "border-color-focus"
        },
        "quote": {
          "$type": "color",
          "$value": "{color.base.neutral.400}"
        },
        "card": {
          "$type": "color",
          "$value": "#00000000",
          "cssProp": "border-color-card"
        }
      },
      "font": {
        "base": {
          "$type": "color",
          "$value": {
            "value": "{color.base.black}"
          },
          "cssProp": "font-color-base"
        },
        "baseInverted": {
          "$type": "color",
          "$value": "{color.base.white}"
        },
        "muted": {
          "$type": "color",
          "$value": {
            "value": "{color.base.neutral.500}"
          },
          "cssProp": "font-color-muted"
        },
        "quote": {
          "$type": "color",
          "$value": {
            "value": "{color.base.neutral.500}"
          },
          "cssProp": "font-color-quote"
        },
        "tooltip": {
          "$type": "color",
          "$value": {
            "value": "{color.base.white}"
          },
          "cssProp": "font-color-tooltip"
        }
      }
    }
  }
